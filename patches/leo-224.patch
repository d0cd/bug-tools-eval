diff --git a/tests/tests/compiler/network/span_network.leo b/tests/tests/compiler/network/span_network.leo
new file mode 100644
index 0000000000..887e1f861f
--- /dev/null
+++ b/tests/tests/compiler/network/span_network.leo
@@ -0,0 +1,18 @@
+// The purpose of this test is to make sure reporting the `no_transition` error
+// works - the `network` member of `ProgramScope` was not getting the correct
+// `Span` during parsing, and consequently when display an error with multiple
+// source files, a panic could happen.
+
+program child.aleo {
+    transition main() {}
+}
+
+// --- Next Program --- //
+
+import child.aleo;
+program parent.aleo {
+    function f(x :u8) {
+        assert_eq(x, x);
+    }
+}
+
