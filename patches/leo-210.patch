+/*
+namespace: Compile
+expectation: Pass
+input_file:
+ - inputs/u8_u8.in
+*/
+
+function main(a: u8, b: u8) -> (u8, u8) {
+    if (a == b) {
+        return (a, b);
+    }
+    let c: u8 = a + b;
+    let d: u8 = a - b;
+    return (c, d);
+}
