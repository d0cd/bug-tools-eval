diff --git a/tests/compiler/statements/loop_non_literal_bound_fail.leo b/tests/compiler/statements/loop_non_literal_bound_fail.leo
new file mode 100644
index 0000000000..8f2b8b6857
--- /dev/null
+++ b/tests/compiler/statements/loop_non_literal_bound_fail.leo
@@ -0,0 +1,24 @@
+/*
+namespace: Compile
+expectation: Fail
+*/
+
+program test.aleo {
+    record Token {
+        owner: address,
+        gates: u64,
+        amount: u64,
+    }
+
+    transition main(owner: address, amount: u64) -> Token {
+        let max: u64 = 0u64;
+        for i:u64 in 0u64..amount {
+            max = i;
+        }
+        return Token {
+            owner: owner,
+            gates: 0u64,
+            amount: amount,
+        };
+    }
+}
