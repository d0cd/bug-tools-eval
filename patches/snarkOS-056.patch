diff --git a/node/bft/events/src/helpers/codec.rs b/node/bft/events/src/helpers/codec.rs
index e2b575def..453476318 100644
--- a/node/bft/events/src/helpers/codec.rs
+++ b/node/bft/events/src/helpers/codec.rs
@@ -108,6 +108,21 @@ pub enum EventOrBytes<N: Network> {
     Event(Event<N>),
 }
 
+impl<N: Network> ToBytes for EventOrBytes<N> {
+    fn write_le<W: io::Write>(&self, mut writer: W) -> io::Result<()> {
+        match self {
+            Self::Bytes(bytes) => {
+                0u8.write_le(&mut writer)?;
+                writer.write_all(bytes)
+            }
+            Self::Event(event) => {
+                1u8.write_le(&mut writer)?;
+                event.write_le(writer)
+            }
+        }
+    }
+}
