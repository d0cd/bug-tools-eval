+program test.aleo {
+    transition main() {
+        let a0: u8 = 1;
+        let a1: u16 = 1;
+        let a2: u32 = 1;
+        let a3: u64 = 1;
+        let a4: u128 = 1;
+        let a5: i8 = 1;
+        let a6: i16 = 1;
+        let a7: i32 = 1;
