+
+function create_wrapper:
+    cast 1u32 2u32 into r0 as Woo;
+    cast r0 into r1 as BooHoo;
+    async create_wrapper r1 into r2;
+    output r2[0u32] as BooHoo.private;
+    output r2 as grandchild.aleo/create_wrapper.future;
