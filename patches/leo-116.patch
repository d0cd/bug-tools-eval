diff --git a/tests/compiler/structs/struct_access_fail.leo b/tests/compiler/structs/struct_access_fail.leo
new file mode 100644
index 0000000000..acaf1769a5
--- /dev/null
+++ b/tests/compiler/structs/struct_access_fail.leo
@@ -0,0 +1,19 @@
+/*
+namespace: Compile
+expectation: Fail
+*/
+
+
+program test.aleo {
+    struct s1 {
+        f1: u32,
+        f2: u32
+    }
+
+    transition main(id_type: i8, s: s1) -> i8 {
+        let x: i8 = s.f1;
+        x = x + 1i8;
+        return x;
+    }
+}
+
