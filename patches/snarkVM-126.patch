+                Value::from_str(&format!("{}", wrapper_program_id.to_address().unwrap())).unwrap(),
+                Value::from_str(&format!("{}u64", ledger_committee::MIN_VALIDATOR_STAKE)).unwrap(),
+            ]
+            .iter(),
+            None,
+            0,
+            None,
+            rng,
