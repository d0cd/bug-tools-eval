+        // Check that both transactions were accepted.
+        assert_eq!(block.transactions().num_accepted(), 2);
+
+        // Update the VM.
+        vm.add_next_block(&block).unwrap();
+
+        // Call the wrapper program to bond as a validator.
+        let result = vm.execute(
