diff --git a/tests/tests/compiler/array/array_write_struct_init.leo b/tests/tests/compiler/array/array_write_struct_init.leo
new file mode 100644
index 0000000000..ff2d93303d
--- /dev/null
+++ b/tests/tests/compiler/array/array_write_struct_init.leo
@@ -0,0 +1,26 @@
+
+program test.aleo {
+    struct S {
+        x: [field; 2]
+    }
+
+    transition main() -> S {
+        let array: [field; 2] = [1field, 1field];
+        array[0] = 2field;
+        // See bug #28711 - the write was not being captured.
+        return S {
+            x: array,
+        };
+    }
+
+    transition main2() -> S {
+        let array: [field; 2] = [1field, 1field];
+        for i in 0u32..2u32 {
+            array[i] = 2field;
+        }
+        // See bug #28711 - the write was not being captured.
+        return S {
+            x: array,
+        };
+    }
+}
