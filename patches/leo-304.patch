diff --git a/tests/tests/compiler/array/array_assign_in_external.leo b/tests/tests/compiler/array/array_assign_in_external.leo
new file mode 100644
index 0000000000..f657bcb4d3
--- /dev/null
+++ b/tests/tests/compiler/array/array_assign_in_external.leo
@@ -0,0 +1,18 @@
+// This test ensures that `WriteTransforming` works on array assignment in Leo stubs
+
+program child.aleo {
+    fn foo(b: u32) -> [u32; 3] {
+        let a = [b; 3];
+        a[0] = 1;
+        a[1] = 2;
+        a[2] = 3;
+        return a;
+    }
+}
+
+// --- Next Program --- //
+
+import child.aleo;
+program parent.aleo {
+    fn main() { }
+}
diff --git a/tests/tests/compiler/function/inline_in_external.leo b/tests/tests/compiler/function/inline_in_external.leo
new file mode 100644
index 0000000000..eeea963b29
--- /dev/null
+++ b/tests/tests/compiler/function/inline_in_external.leo
@@ -0,0 +1,25 @@
+// This test ensures that `FunctionInlining` works in Leo stubs
+
+program child.aleo {
+    fn foo() -> Final {
+        return final {
+            assert(f() == 4);
+            assert(f() != 4);
+        };
+    }
+}
+
+fn f() -> u32 { return 4; }
+
+// --- Next Program --- //
+
+import child.aleo;
+program parent.aleo {
+    fn foo() -> Final {
+        return final {
+            assert(f() == 4);
+        };
+    }
+}
+
+fn f() -> u32 { return 4; }
